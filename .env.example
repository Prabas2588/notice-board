# Copy this file to .env and fill in your real database connection string.
# Get this from TiDB Cloud (or Neon/Supabase) after creating a free database.
#
# TiDB Cloud (MySQL) example:
# DATABASE_URL="mysql://USER:PASSWORD@HOST:4000/DBNAME?sslaccept=strict"
#
# Neon (Postgres) example — also requires changing provider to "postgresql"
# in prisma/schema.prisma:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

DATABASE_URL=""
